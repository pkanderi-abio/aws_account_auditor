# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is listed in .gitignore.

[supabase]
url              = "https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
anon_key         = "eyJ..."         # Project Settings → API → anon/public key
service_role_key = "eyJ..."         # Project Settings → API → service_role key (keep secret!)

# AI — Groq is free and works on Streamlit Cloud (https://console.groq.com)
GROQ_API_KEY = "gsk_..."            # optional but recommended
# GROQ_MODEL = "llama-3.1-8b-instant"   # default; override if desired

[aws]
AWS_ACCESS_KEY_ID     = "AKIA..."
AWS_SECRET_ACCESS_KEY = "..."
